---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchPublicVideos, getVideoTitle } from "../../lib/videos";

const videos = await fetchPublicVideos();
const dateFormatter = new Intl.DateTimeFormat("ja-JP", {
  dateStyle: "long",
});

function formatPublishedAt(value: string): string {
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
}
---

<BaseLayout title="azuki.blue - パラパラ動画">
  <main class="paravi-main">
    <section class="paravi-hero">
      <p class="eyebrow">ParaPara Archive</p>
      <h1>パラパラ動画</h1>
      <p class="lead">
        Youtube で公開しているリンクをまとめています。細かいフリの違いはご容赦ください。
      </p>
    </section>

    {
      videos.length === 0 ? (
        <section class="empty-state">
          <h2>公開中の動画がありません</h2>
          <p>microCMS か mock API のデータを確認してください。</p>
        </section>
      ) : (
        <section class="video-grid" aria-label="パラパラ動画一覧">
          {videos.map((video) => (
            <article class="video-card">
              <div class="video-frame">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${video.youtubeVideoId}`}
                  title={`${getVideoTitle(video)} の埋め込みプレイヤー`}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              </div>

              <div class="video-body">
                <div class="video-meta">
                  <p class="video-date">公開日: {formatPublishedAt(video.youtubePublishedAt)}</p>
                </div>

                <h2>{getVideoTitle(video)}</h2>

                <div class="actions">
                  {video.downloadUrl ? (
                    <a class="download-link" href={video.downloadUrl} target="_blank" rel="noopener noreferrer">
                      ダウンロード
                    </a>
                  ) : (
                    <span class="download-placeholder">ダウンロードリンク準備中</span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .paravi-main {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 2rem 0 3rem;
  }

  .paravi-hero {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    background:
      radial-gradient(circle at top right, rgba(103, 232, 249, 0.4), transparent 35%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.75), rgba(236, 72, 153, 0.08));
    box-shadow: 0 18px 40px rgba(76, 5, 25, 0.08);
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-pink);
  }

  .paravi-hero h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 1.1;
  }

  .lead {
    margin: 0;
    max-width: 48rem;
    color: var(--text-secondary);
  }

  .empty-state {
    padding: 2rem;
    border: 1px dashed var(--border-color);
    border-radius: 16px;
    background-color: rgba(255, 255, 255, 0.7);
  }

  .empty-state h2,
  .empty-state p {
    margin: 0;
  }

  .empty-state p {
    margin-top: 0.5rem;
    color: var(--text-secondary);
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .video-card {
    overflow: hidden;
    border: 1px solid var(--border-color);
    border-radius: 18px;
    background-color: rgba(255, 255, 255, 0.88);
    box-shadow: 0 16px 36px rgba(131, 24, 67, 0.12);
  }

  .video-frame {
    position: relative;
    padding-top: 56.25%;
    background:
      linear-gradient(135deg, rgba(103, 232, 249, 0.16), rgba(236, 72, 153, 0.16)),
      #fff;
  }

  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-body {
    display: grid;
    gap: 0.8rem;
    padding: 1rem 1rem 1.2rem;
  }

  .video-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
  }

  .video-date {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.88rem;
  }

  .video-body h2 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .download-link,
  .download-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.7rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .download-link {
    background: rgba(236, 72, 153, 0.05);
    color: var(--accent);
    border: 1px solid rgba(236, 72, 153, 0.12);
    text-decoration: none;
  }

  .download-link:hover {
    background: rgba(236, 72, 153, 0.09);
  }

  .download-placeholder {
    border: 1px dashed var(--border-color);
    color: var(--text-secondary);
    background-color: rgba(236, 72, 153, 0.03);
  }

  @media (max-width: 720px) {
    .paravi-main {
      width: min(100vw - 1rem, 42rem);
      padding-top: 1rem;
    }

    .paravi-hero,
    .video-body {
      padding-left: 0.9rem;
      padding-right: 0.9rem;
    }
  }
</style>
