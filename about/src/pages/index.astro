---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
---

<BaseLayout title="azuki.blue - ポートフォリオ & サーバ紹介">
  <main class="portfolio-main">
    <section id="hero" class="hero">
      <h1>azuki.blue</h1>
      <p class="hero-catch">ポートフォリオなど（Coming soon）</p>
    </section>

    <Section id="about" title="azuki について">
      <div class="subsection">
        <h3>各種アカウント</h3>
        <p>Coming soon</p>
      </div>
      <div class="subsection">
        <h3>スキル（主にITエンジニアリングについて）</h3>
        <p>Coming soon</p>
      </div>
    </Section>

    <Section id="azkey" title="azkey.azuki.blue （あずきインターネット）について">
      <p>Coming soon</p>
    </Section>

    <Section id="nostr" title="nostr.azuki.blue （Nostrリレーサーバ）について">
      <p>Coming soon</p>
    </Section>

    <section id="parapara" class="parapara-section">
      <h2>パラパラ動画</h2>
      <p>別ページ予定</p>
      <p><a href="/paravi/">パラビリンク集へ</a>（準備中）</p>
    </section>
  </main>
</BaseLayout>

<style>
  .portfolio-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
  }
  .hero {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border-color);
    background: linear-gradient(135deg, rgba(236, 72, 153, 0.12) 0%, rgba(251, 207, 232, 0.2) 100%);
  }
  .hero h1 {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
    color: var(--accent);
  }
  .hero-catch {
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.9;
  }
  .subsection {
    margin-bottom: 1rem;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background-color: var(--bg-sub);
  }
  .subsection:last-child {
    margin-bottom: 0;
  }
  .subsection h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-pink);
  }
  .subsection p {
    margin: 0;
    font-size: 0.9rem;
  }
  .parapara-section {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }
  .parapara-section h2 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    color: var(--accent);
  }
  .parapara-section p {
    margin: 0 0 0.5rem;
  }
  .parapara-section a {
    color: var(--accent);
    text-decoration: none;
  }
  .parapara-section a:hover {
    color: var(--color-pink);
    text-decoration: underline;
  }
</style>
