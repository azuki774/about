---
interface Props {
  title: string;
  id: string;
}
const { title, id } = Astro.props;
---
<section id={id}>
  <h2>{title}</h2>
  <slot />
</section>

<style>
  section {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-color, #e0e0e0);
  }
  section:last-of-type {
    border-bottom: none;
  }
  h2 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
  }
</style>
