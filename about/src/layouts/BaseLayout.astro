---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">azuki.blue</a>
      <nav class="site-nav">
        <a href="#about">azuki について</a>
        <a href="#azkey">azkey.azuki.blue</a>
        <a href="#nostr">nostr.azuki.blue</a>
        <a href="/paravi/">パラパラ動画</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>azuki.blue</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* 水色・ピンク（ピンク基調・ヘッダーだけ水色） */
    --color-aqua: #67e8f9;
    --color-pink: #ec4899;
    --color-green: #2dd4bf;
    --bg-base: #fdf2f8;
    --bg-sub: rgba(236, 72, 153, 0.08);
    --text-primary: #4c0519;
    --text-secondary: #831843;
    --border-color: rgba(236, 72, 153, 0.35);
    --accent: #be185d;
    --header-bg: rgba(103, 232, 249, 0.25);
    --header-border: rgba(103, 232, 249, 0.5);
    --font-body: "Noto Sans JP", sans-serif;
  }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: var(--font-body);
    line-height: 1.6;
    background-color: var(--bg-base);
    color: var(--text-primary);
  }
</style>

<style>
  .site-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--header-border);
    background-color: var(--header-bg);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .site-title {
    font-weight: bold;
    text-decoration: none;
    color: var(--accent);
  }
  .site-title:hover {
    color: var(--color-pink);
    text-decoration: underline;
  }
  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .site-nav a {
    text-decoration: none;
    color: var(--accent);
    font-size: 0.9rem;
  }
  .site-nav a:hover {
    color: var(--color-pink);
    text-decoration: underline;
  }
  .site-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--border-color);
    background-color: var(--bg-sub);
    margin-top: 2rem;
    font-size: 0.9rem;
  }
  .site-footer p {
    margin: 0;
  }
</style>
